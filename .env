# .env 文件内容
# ========================================
# 数据库配置（PostgreSQL）
# ========================================
DB_NAME=blog
DB_USER=blog
DB_PASSWORD=StrongPass123!  # ✅ 改为强密码
DB_HOST=db
DB_PORT=5432

# ========================================
# 邮箱配置（Gmail示例）- 需要时取消注释
# ========================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_account@gmail.com
# EMAIL_HOST_PASSWORD=xxxxxxxxxxxx  # Gmail应用密码
# DEFAULT_FROM_EMAIL=My Blog <your_account@gmail.com>

# ========================================
# Django安全配置
# ========================================
# ✅ 使用强SECRET_KEY
SECRET_KEY=django-insecure-8^g$#7f@2!k&p9m%x6z5y4a3b1c0d9e8f7g6h5i4j3k2l1m0n9o8p7q6r5s4t3

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# 可选：SQLite配置（如果您用SQLite）
# ========================================
# 如果使用SQLite，可以注释掉上面的数据库配置，使用这个：
# USE_SQLITE=True